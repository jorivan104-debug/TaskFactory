model WorkOrder {
  id                          String    @id @default(uuid()) @db.Uuid
  workOrderTypeId             String?   @map("work_order_type_id") @db.Uuid
  workSiteId                  String    @map("work_site_id") @db.Uuid
  code                        String    @unique @db.VarChar(64)
  title                       String?   @db.VarChar(255)
  status                      String    @db.VarChar(32)
  productionType              String?   @map("production_type") @db.VarChar(32)
  patternSupplierId           String?   @map("pattern_supplier_id") @db.Uuid
  patterningDays              Int?      @map("patterning_days")
  designInstructions          String?   @map("design_instructions")
  designInstructionsUpdatedAt DateTime? @map("design_instructions_updated_at") @db.Timestamptz
  designAttachmentsJson       Json?     @map("design_attachments_json")
  closedAt                    DateTime? @map("closed_at") @db.Timestamptz
  closedByUserId              String?   @map("closed_by_user_id") @db.Uuid
  currentStateKey             String?   @map("current_state_key") @db.VarChar(128)
  blueprintVersion            Int?      @map("blueprint_version")
  blueprintSnapshotJson       Json?     @map("blueprint_snapshot_json")
  createdAt                   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId             String    @map("created_by_user_id") @db.Uuid

