generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── MULTI-SITE ───────────────────────────────────────────

model WorkSite {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(32)
  name      String   @db.VarChar(255)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId String @map("created_by_user_id") @db.Uuid

  createdBy  User        @relation("WorkSiteCreator", fields: [createdByUserId], references: [id])
  warehouses Warehouse[]
  workOrders WorkOrder[]
  userRoles  UserRole[]

  @@map("work_sites")
}

model Warehouse {
  id         String   @id @default(uuid()) @db.Uuid
  workSiteId String?  @map("work_site_id") @db.Uuid
  code       String   @unique @db.VarChar(32)
  name       String   @db.VarChar(255)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId String @map("created_by_user_id") @db.Uuid

  createdBy       User                  @relation("WarehouseCreator", fields: [createdByUserId], references: [id])
  workSite        WorkSite?             @relation(fields: [workSiteId], references: [id])
  stockLots       InventoryStockLot[]
  movements       InventoryMovement[]
  purchaseReceipts SupplyPurchaseReceipt[]
  purchaseOrders  SupplyPurchaseOrder[] @relation("DefaultWarehouse")

  @@map("warehouses")
}

// ─── AUTH & RBAC ──────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name") @db.VarChar(255)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId String? @map("created_by_user_id") @db.Uuid

  createdBy User? @relation("UserCreator", fields: [createdByUserId], references: [id])
  createdUsers User[] @relation("UserCreator")

  userRoles      UserRole[]
  auditLogs      AuditLog[]

  // Creator relations
  createdWorkSites     WorkSite[]              @relation("WorkSiteCreator")
  createdWarehouses    Warehouse[]             @relation("WarehouseCreator")
  createdBrands        Brand[]                 @relation("BrandCreator")
  createdSilhouetteCats SilhouetteCategory[]   @relation("SilCatCreator")
  createdSilhouettes   Silhouette[]            @relation("SilhouetteCreator")
  createdSuppliers     Supplier[]              @relation("SupplierCreator")
  createdSupplyTypes   SupplyType[]            @relation("SupplyTypeCreator")
  createdSupplies      Supply[]                @relation("SupplyCreator")
  sellerSupplies       Supply[]                @relation("SupplySeller")
  createdPantoneColors PantoneColor[]          @relation("PantoneCreator")
  createdSizes         Size[]                  @relation("SizeCreator")
  createdUnitsOfMeasure UnitOfMeasure[]        @relation("UomCreator")
  createdGarmentRefs   GarmentReference[]      @relation("GarmentRefCreator")
  createdWorkOrders    WorkOrder[]             @relation("WOCreator")
  closedWorkOrders     WorkOrder[]             @relation("WOCloser")
  createdWOColors      WorkOrderPantoneColor[] @relation("WOColorCreator")
  createdWOLogs        WorkOrderLog[]          @relation("WOLogCreator")
  createdSizeCurves    WorkOrderSizeCurveItem[] @relation("SizeCurveCreator")
  createdRoles         Role[]                  @relation("RoleCreator")
  createdUserRoles     UserRole[]              @relation("UserRoleCreator")

  createdPurchaseOrders     SupplyPurchaseOrder[]        @relation("SPOCreator")
  createdPurchaseItems      SupplyPurchaseOrderItem[]    @relation("SPOItemCreator")
  createdPurchaseReceipts   SupplyPurchaseReceipt[]      @relation("SPRCreator")
  createdReceiptItems       SupplyPurchaseReceiptItem[]  @relation("SPRItemCreator")
  createdSupplierInvoices   SupplierInvoice[]            @relation("SICreator")
  createdInvoiceLines       SupplierInvoiceLine[]        @relation("SILineCreator")
  createdSupplierPayments   SupplierPayment[]            @relation("SPCreator")
  createdPaymentAllocations SupplierPaymentAllocation[]  @relation("SPACreator")

  createdProducts       Product[]              @relation("ProductCreator")
  createdStockLots      InventoryStockLot[]    @relation("StockLotCreator")
  createdMovements      InventoryMovement[]    @relation("MovementCreator")
  createdSyncRequests   AccountingSyncRequest[] @relation("SyncReqCreator")

  createdInternalOrders InternalOrder[]        @relation("IOCreator")
  approvedInternalOrders InternalOrder[]       @relation("IOApprover")
  createdIOItems        InternalOrderItem[]    @relation("IOItemCreator")
  createdEmployees      Employee[]             @relation("EmployeeCreator")
  createdTimeEntries    TimeEntry[]            @relation("TimeEntryCreator")
  createdTaskAssignments TaskAssignment[]      @relation("TaskAssignmentCreator")
  createdThirdPartyServices ThirdPartyService[] @relation("TPSCreator")
  createdShipments      Shipment[]             @relation("ShipmentCreator")
  createdShipmentItems  ShipmentItem[]         @relation("ShipmentItemCreator")
  createdWOTypes        WorkOrderType[]        @relation("WOTypeCreator")
  createdBlueprints     WorkOrderBlueprint[]   @relation("BlueprintCreator")

  @@map("users")
}

model Role {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(64)
  name      String   @db.VarChar(128)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId String @map("created_by_user_id") @db.Uuid

  createdBy User       @relation("RoleCreator", fields: [createdByUserId], references: [id])
  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  workSiteId String?  @map("work_site_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  createdByUserId String @map("created_by_user_id") @db.Uuid

  user      User     @relation(fields: [userId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id])
  workSite  WorkSite? @relation(fields: [workSiteId], references: [id])
  createdBy User     @relation("UserRoleCreator", fields: [createdByUserId], references: [id])

  @@unique([userId, roleId, workSiteId])
  @@map("user_roles")
}

// ─── CATALOGS ─────────────────────────────────────────────

model Brand {
  id                    String   @id @default(uuid()) @db.Uuid
  name                  String   @db.VarChar(255)
  abbreviation          String   @unique @db.VarChar(32)
  consecutivo           Int      @unique
  logoUrl               String?  @map("logo_url")
  nextReferenceSequence BigInt   @default(1) @map("next_reference_sequence")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId       String   @map("created_by_user_id") @db.Uuid

  createdBy       User               @relation("BrandCreator", fields: [createdByUserId], references: [id])
  garmentReferences GarmentReference[]

  @@map("brands")
}

model SilhouetteCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(128)
  sortOrder Int?     @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId String @map("created_by_user_id") @db.Uuid

  createdBy   User          @relation("SilCatCreator", fields: [createdByUserId], references: [id])
  silhouettes Silhouette[]

  @@map("silhouette_categories")
}

model Silhouette {
  id                   String   @id @default(uuid()) @db.Uuid
  name                 String   @db.VarChar(255)
  silhouetteCategoryId String   @map("silhouette_category_id") @db.Uuid
  gender               String?  @db.VarChar(32)
  description          String?
  imageUrl             String?  @map("image_url")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId      String   @map("created_by_user_id") @db.Uuid

  createdBy         User                @relation("SilhouetteCreator", fields: [createdByUserId], references: [id])
  silhouetteCategory SilhouetteCategory @relation(fields: [silhouetteCategoryId], references: [id])
  garmentReferences GarmentReference[]

  @@map("silhouettes")
}

model PantoneColor {
  id            String   @id @default(uuid()) @db.Uuid
  pantoneSystem String   @map("pantone_system") @db.VarChar(16)
  pantoneCode   String   @map("pantone_code") @db.VarChar(32)
  pantoneLabel  String?  @map("pantone_label") @db.VarChar(128)
  name          String?  @db.VarChar(255)
  hexApprox     String?  @map("hex_approx") @db.Char(7)
  rgbR          Int?     @map("rgb_r") @db.SmallInt
  rgbG          Int?     @map("rgb_g") @db.SmallInt
  rgbB          Int?     @map("rgb_b") @db.SmallInt
  labL          Decimal? @map("lab_l") @db.Decimal(6, 3)
  labA          Decimal? @map("lab_a") @db.Decimal(6, 3)
  labB          Decimal? @map("lab_b") @db.Decimal(6, 3)
  notes         String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId String @map("created_by_user_id") @db.Uuid

  createdBy         User                     @relation("PantoneCreator", fields: [createdByUserId], references: [id])
  garmentReferences GarmentReference[]
  workOrderColors   WorkOrderPantoneColor[]

  @@unique([pantoneSystem, pantoneCode])
  @@map("pantone_colors")
}

model Size {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(64)
  sortOrder Int?     @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId String @map("created_by_user_id") @db.Uuid

  createdBy  User                        @relation("SizeCreator", fields: [createdByUserId], references: [id])
  sizeCurves WorkOrderSizeCurveItem[]

  @@map("sizes")
}

model UnitOfMeasure {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(16)
  name      String   @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId String @map("created_by_user_id") @db.Uuid

  createdBy       User                        @relation("UomCreator", fields: [createdByUserId], references: [id])
  supplies        Supply[]
  purchaseItems   SupplyPurchaseOrderItem[]
  stockLots       InventoryStockLot[]
  movements       InventoryMovement[]

  @@map("units_of_measure")
}

model SupplyType {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(32)
  name      String   @db.VarChar(128)
  sortOrder Int?     @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId String @map("created_by_user_id") @db.Uuid

  createdBy User     @relation("SupplyTypeCreator", fields: [createdByUserId], references: [id])
  supplies  Supply[]

  @@map("supply_types")
}

// ─── SUPPLIERS & SUPPLIES ─────────────────────────────────

model Supplier {
  id            String   @id @default(uuid()) @db.Uuid
  legalName     String   @map("legal_name") @db.VarChar(255)
  tradeName     String?  @map("trade_name") @db.VarChar(255)
  taxId         String?  @map("tax_id") @db.VarChar(64)
  country       String?  @db.VarChar(64)
  city          String?  @db.VarChar(128)
  address       String?
  phone         String?  @db.VarChar(64)
  email         String?  @db.VarChar(255)
  website       String?  @db.VarChar(255)
  contactPerson String?  @map("contact_person") @db.VarChar(255)
  notes         String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId String @map("created_by_user_id") @db.Uuid

  createdBy       User                   @relation("SupplierCreator", fields: [createdByUserId], references: [id])
  supplies        Supply[]               @relation("DefaultSupplier")
  purchaseOrders  SupplyPurchaseOrder[]
  invoices        SupplierInvoice[]
  payments        SupplierPayment[]
  workOrders      WorkOrder[]            @relation("PatternSupplier")

  @@map("suppliers")
}

model Supply {
  id                String   @id @default(uuid()) @db.Uuid
  name              String   @db.VarChar(255)
  supplyTypeId      String   @map("supply_type_id") @db.Uuid
  sellerUserId      String   @map("seller_user_id") @db.Uuid
  defaultSupplierId String?  @map("default_supplier_id") @db.Uuid
  unitOfMeasureId   String   @map("unit_of_measure_id") @db.Uuid
  stockOnHand       Decimal  @default(0) @map("stock_on_hand") @db.Decimal(18, 4)
  stockOnWay        Decimal  @default(0) @map("stock_on_way") @db.Decimal(18, 4)
  purchaseUnitPrice Decimal? @map("purchase_unit_price") @db.Decimal(18, 4)
  sku               String?  @db.VarChar(64)
  description       String?
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId   String   @map("created_by_user_id") @db.Uuid

  createdBy        User            @relation("SupplyCreator", fields: [createdByUserId], references: [id])
  seller           User            @relation("SupplySeller", fields: [sellerUserId], references: [id])
  supplyType       SupplyType      @relation(fields: [supplyTypeId], references: [id])
  defaultSupplier  Supplier?       @relation("DefaultSupplier", fields: [defaultSupplierId], references: [id])
  unitOfMeasure    UnitOfMeasure   @relation(fields: [unitOfMeasureId], references: [id])
  garmentReferences GarmentReference[] @relation("FabricSupply")
  purchaseItems    SupplyPurchaseOrderItem[]
  stockLots        InventoryStockLot[]
  movements        InventoryMovement[]

  @@map("supplies")
}

// ─── PURCHASING ───────────────────────────────────────────

model SupplyPurchaseOrder {
  id                 String   @id @default(uuid()) @db.Uuid
  code               String   @unique @db.VarChar(64)
  supplierId         String   @map("supplier_id") @db.Uuid
  status             String   @db.VarChar(32)
  orderedAt          DateTime? @map("ordered_at") @db.Timestamptz
  expectedAt         DateTime? @map("expected_at") @db.Date
  defaultWarehouseId String?  @map("default_warehouse_id") @db.Uuid
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId    String   @map("created_by_user_id") @db.Uuid

  createdBy        User                       @relation("SPOCreator", fields: [createdByUserId], references: [id])
  supplier         Supplier                   @relation(fields: [supplierId], references: [id])
  defaultWarehouse Warehouse?                 @relation("DefaultWarehouse", fields: [defaultWarehouseId], references: [id])
  items            SupplyPurchaseOrderItem[]
  receipts         SupplyPurchaseReceipt[]

  @@map("supply_purchase_orders")
}

model SupplyPurchaseOrderItem {
  id                    String   @id @default(uuid()) @db.Uuid
  supplyPurchaseOrderId String   @map("supply_purchase_order_id") @db.Uuid
  supplyId              String   @map("supply_id") @db.Uuid
  quantityOrdered       Decimal  @map("quantity_ordered") @db.Decimal(18, 4)
  quantityReceived      Decimal  @default(0) @map("quantity_received") @db.Decimal(18, 4)
  unitOfMeasureId       String   @map("unit_of_measure_id") @db.Uuid
  unitPrice             Decimal? @map("unit_price") @db.Decimal(18, 4)
  lineTotal             Decimal? @map("line_total") @db.Decimal(18, 4)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId       String   @map("created_by_user_id") @db.Uuid

  createdBy      User                          @relation("SPOItemCreator", fields: [createdByUserId], references: [id])
  purchaseOrder  SupplyPurchaseOrder           @relation(fields: [supplyPurchaseOrderId], references: [id])
  supply         Supply                        @relation(fields: [supplyId], references: [id])
  unitOfMeasure  UnitOfMeasure                 @relation(fields: [unitOfMeasureId], references: [id])
  receiptItems   SupplyPurchaseReceiptItem[]
  invoiceLines   SupplierInvoiceLine[]

  @@unique([supplyPurchaseOrderId, supplyId])
  @@map("supply_purchase_order_items")
}

model SupplyPurchaseReceipt {
  id                    String   @id @default(uuid()) @db.Uuid
  supplyPurchaseOrderId String   @map("supply_purchase_order_id") @db.Uuid
  warehouseId           String   @map("warehouse_id") @db.Uuid
  receivedAt            DateTime @map("received_at") @db.Timestamptz
  status                String   @db.VarChar(32)
  notes                 String?
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId       String   @map("created_by_user_id") @db.Uuid

  createdBy     User                          @relation("SPRCreator", fields: [createdByUserId], references: [id])
  purchaseOrder SupplyPurchaseOrder           @relation(fields: [supplyPurchaseOrderId], references: [id])
  warehouse     Warehouse                     @relation(fields: [warehouseId], references: [id])
  items         SupplyPurchaseReceiptItem[]

  @@map("supply_purchase_receipts")
}

model SupplyPurchaseReceiptItem {
  id                       String   @id @default(uuid()) @db.Uuid
  supplyPurchaseReceiptId  String   @map("supply_purchase_receipt_id") @db.Uuid
  supplyPurchaseOrderItemId String  @map("supply_purchase_order_item_id") @db.Uuid
  quantityReceived         Decimal  @map("quantity_received") @db.Decimal(18, 4)
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz
  createdByUserId          String   @map("created_by_user_id") @db.Uuid

  createdBy     User                     @relation("SPRItemCreator", fields: [createdByUserId], references: [id])
  receipt       SupplyPurchaseReceipt    @relation(fields: [supplyPurchaseReceiptId], references: [id])
  orderItem     SupplyPurchaseOrderItem  @relation(fields: [supplyPurchaseOrderItemId], references: [id])

  @@map("supply_purchase_receipt_items")
}

model SupplierInvoice {
  id            String   @id @default(uuid()) @db.Uuid
  supplierId    String   @map("supplier_id") @db.Uuid
  invoiceNumber String   @map("invoice_number") @db.VarChar(64)
  invoiceDate   DateTime @map("invoice_date") @db.Date
  dueDate       DateTime? @map("due_date") @db.Date
  currency      String   @db.Char(3)
  subtotal      Decimal  @db.Decimal(18, 4)
  taxAmount     Decimal? @map("tax_amount") @db.Decimal(18, 4)
  total         Decimal  @db.Decimal(18, 4)
  status        String   @db.VarChar(32)
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId String @map("created_by_user_id") @db.Uuid

  createdBy    User                        @relation("SICreator", fields: [createdByUserId], references: [id])
  supplier     Supplier                    @relation(fields: [supplierId], references: [id])
  lines        SupplierInvoiceLine[]
  allocations  SupplierPaymentAllocation[]

  @@unique([supplierId, invoiceNumber])
  @@map("supplier_invoices")
}

model SupplierInvoiceLine {
  id                       String   @id @default(uuid()) @db.Uuid
  supplierInvoiceId        String   @map("supplier_invoice_id") @db.Uuid
  supplyPurchaseOrderItemId String? @map("supply_purchase_order_item_id") @db.Uuid
  description              String?  @db.VarChar(255)
  quantity                 Decimal? @db.Decimal(18, 4)
  unitPrice                Decimal? @map("unit_price") @db.Decimal(18, 4)
  lineTotal                Decimal  @map("line_total") @db.Decimal(18, 4)
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz
  createdByUserId          String   @map("created_by_user_id") @db.Uuid

  createdBy   User                     @relation("SILineCreator", fields: [createdByUserId], references: [id])
  invoice     SupplierInvoice          @relation(fields: [supplierInvoiceId], references: [id])
  orderItem   SupplyPurchaseOrderItem? @relation(fields: [supplyPurchaseOrderItemId], references: [id])

  @@map("supplier_invoice_lines")
}

model SupplierPayment {
  id            String   @id @default(uuid()) @db.Uuid
  supplierId    String   @map("supplier_id") @db.Uuid
  paidAt        DateTime @map("paid_at") @db.Timestamptz
  amount        Decimal  @db.Decimal(18, 4)
  currency      String   @db.Char(3)
  paymentMethod String?  @map("payment_method") @db.VarChar(32)
  reference     String?  @db.VarChar(128)
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId String @map("created_by_user_id") @db.Uuid

  createdBy    User                        @relation("SPCreator", fields: [createdByUserId], references: [id])
  supplier     Supplier                    @relation(fields: [supplierId], references: [id])
  allocations  SupplierPaymentAllocation[]

  @@map("supplier_payments")
}

model SupplierPaymentAllocation {
  id                String   @id @default(uuid()) @db.Uuid
  supplierPaymentId String   @map("supplier_payment_id") @db.Uuid
  supplierInvoiceId String   @map("supplier_invoice_id") @db.Uuid
  amount            Decimal  @db.Decimal(18, 4)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  createdByUserId   String   @map("created_by_user_id") @db.Uuid

  createdBy User            @relation("SPACreator", fields: [createdByUserId], references: [id])
  payment   SupplierPayment @relation(fields: [supplierPaymentId], references: [id])
  invoice   SupplierInvoice @relation(fields: [supplierInvoiceId], references: [id])

  @@map("supplier_payment_allocations")
}

// ─── WORK ORDER TYPES & BLUEPRINTS ────────────────────────

model WorkOrderType {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(32)
  name        String   @db.VarChar(255)
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId String @map("created_by_user_id") @db.Uuid

  createdBy  User                  @relation("WOTypeCreator", fields: [createdByUserId], references: [id])
  blueprint  WorkOrderBlueprint?
  workOrders WorkOrder[]

  @@map("work_order_types")
}

model WorkOrderBlueprint {
  id               String    @id @default(uuid()) @db.Uuid
  workOrderTypeId  String    @unique @map("work_order_type_id") @db.Uuid
  version          Int       @default(1)
  status           String    @default("draft") @db.VarChar(16)
  definitionJson   Json      @map("definition_json")
  publishedAt      DateTime? @map("published_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
