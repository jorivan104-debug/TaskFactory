# Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskfactory?schema=public"

# JWT (compartido con la verificación de tokens)
JWT_SECRET="change-me-in-production"
JWT_EXPIRATION="1d"

PORT=3000

# WorkOS AuthKit (deja vacío para deshabilitar el botón "Continuar con WorkOS")
# Crea una aplicación WorkOS y registra el callback EXACTO en el panel de WorkOS.
WORKOS_API_KEY=""
WORKOS_CLIENT_ID=""
WORKOS_REDIRECT_URI="https://taskfactory.app-sprint.com/api/auth/workos/callback"

# URL pública del frontend (a donde se redirige tras autenticar)
FRONTEND_URL="https://taskfactory.app-sprint.com"
